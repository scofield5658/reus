{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "target": "ES2022",
    "module": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "useUnknownInCatchVariables": false,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "types": ["node"]
  },
  "include": [
    "./.gulpfiles/**/*.ts",
    "./bin/**/*.ts",
    "./src/**/*.ts",
    "./gulpfile.ts",
    "./types/**/*.d.ts"
  ]
}
